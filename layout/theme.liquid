<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#3A6B35">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <meta name="google-site-verification" content="HFfE9dEqe6c-f_medgRMhUHfz6HHxIDKG0alP1YTBHc" />
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18126943260"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18126943260');
  </script>
  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    html, body { transform: none !important; filter: none !important; perspective: none !important; contain: none !important; will-change: auto !important; }
    #shopify-section-header { transform: none !important; filter: none !important; perspective: none !important; contain: none !important; will-change: auto !important; }
    body { padding-top: 120px !important; }
    @media (max-width: 768px) { body { padding-top: 105px !important; } }
  </style>
</head>

<body class="{% if customer %}customer-logged-in{% endif %}">

  {%- render 'pf-header' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}
  {%- sections 'email-popup' -%}

  <button class="back-to-top" id="backToTop" aria-label="Back to top">↑</button>

  <script>
    if (window.location.pathname.startsWith('/policies/')) {
      document.addEventListener('DOMContentLoaded', function() {
        var link = document.createElement('a');
        link.href = document.referrer && document.referrer !== window.location.href ? document.referrer : '/';
        link.textContent = '← Back';
        link.style.cssText = 'display:inline-flex;align-items:center;color:#3A6B35;font-size:14px;font-weight:500;text-decoration:none;margin:24px 0 0 24px;opacity:0.85;';
        link.onmouseover = function(){ this.style.opacity='1'; };
        link.onmouseout = function(){ this.style.opacity='0.85'; };
        var main = document.getElementById('MainContent');
        if (main) main.insertBefore(link, main.firstChild);
      });
    }
  </script>

  <script>
    (function() {
      var header = document.querySelector('.site-header');
      if (header) {
        document.body.appendChild(header);
        header.style.cssText = 'position:fixed!important;top:0!important;left:0!important;right:0!important;width:100%!important;z-index:9999!important;background:#fff;border-bottom:1px solid #E8EDE7;box-shadow:0 2px 8px rgba(0,0,0,0.06);';
        document.body.style.paddingTop = header.offsetHeight + 'px';
      }
    })();
  </script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script>
    function pawfieldAddToCart(btn) {
      var variantId = btn.dataset.variantId;
      if (!variantId) return;
      btn.textContent = '✓';
      btn.style.background = 'var(--green)';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({id: variantId, quantity: 1})
      }).then(function() {
        return fetch('/cart.js');
      }).then(function(r){ return r.json(); }).then(function(cart) {
        var countEl = document.getElementById('cart-count');
        if (countEl) countEl.textContent = cart.item_count;
        setTimeout(function(){ btn.textContent = '+'; btn.style.background = ''; }, 1500);
      }).catch(function() {
        btn.textContent = '+';
        window.location = '/cart';
      });
    }
  </script>
</body>
</html>
