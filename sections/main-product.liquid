{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<style>
  .pdp-breadcrumb {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 24px 0;
  }
  .pdp-breadcrumb a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .pdp-breadcrumb a:hover { opacity: 1; }

  .pdp-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  /* Gallery */
  .pdp-gallery__main {
    position: sticky;
    top: 130px;
  }
  .pdp-gallery__main-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 16px;
    background: #F8F8F6;
    display: block;
  }
  .pdp-gallery__placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: #F8F8F6;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 100px;
  }
  .pdp-gallery__thumbs {
    display: flex;
    gap: 10px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .pdp-gallery__thumb {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
    flex-shrink: 0;
  }
  .pdp-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pdp-gallery__thumb.is-active { border-color: var(--green); }
  .pdp-gallery__thumb:hover { border-color: var(--green); }

  /* Info */
  .pdp-info__category {
    display: inline-block;
    background: #EAF2E9;
    color: var(--green);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 50px;
    margin-bottom: 12px;
  }
  .pdp-info__title {
    font-size: 28px;
    font-weight: 700;
    color: var(--dark);
    line-height: 1.3;
    margin: 0 0 12px;
  }
  .pdp-info__stars {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }
  .pdp-info__stars-icons { color: #F59E0B; font-size: 15px; letter-spacing: 1px; }
  .pdp-info__stars-label { font-size: 13px; color: var(--muted); }

  .pdp-info__price-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .pdp-info__price {
    font-size: 32px;
    font-weight: 700;
    color: var(--dark);
  }
  .pdp-info__compare {
    font-size: 18px;
    color: var(--muted);
    text-decoration: line-through;
  }
  .pdp-info__badge {
    background: #FEF2F2;
    color: #DC2626;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 50px;
  }
  .pdp-info__savings {
    font-size: 14px;
    color: var(--green);
    font-weight: 600;
    margin-bottom: 20px;
  }

  .pdp-info__option-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .pdp-info__variants { margin: 20px 0; }
  .pdp-info__variant-group { margin-bottom: 16px; }

  .pdp-atc {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 24px;
  }
  .pdp-atc__btn {
    width: 100%;
    padding: 18px;
    background: var(--green);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 17px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    letter-spacing: 0.3px;
  }
  .pdp-atc__btn:hover { background: #2D5A28; transform: translateY(-1px); }
  .pdp-atc__btn:disabled { background: #9CA3AF; cursor: not-allowed; transform: none; }

  .pdp-trust {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-top: 20px;
    padding: 16px;
    background: #F8F9F7;
    border-radius: 12px;
  }
  .pdp-trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 500;
    color: #374151;
  }
  .pdp-trust__icon { font-size: 20px; }

  /* Description section */
  .pdp-desc-section {
    max-width: 1200px;
    margin: 60px auto 80px;
    padding: 0 24px;
  }
  .pdp-desc-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .pdp-desc-body h2 {
    font-size: 26px;
    font-weight: 700;
    color: var(--dark);
    margin: 48px 0 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid #EAF2E9;
  }
  .pdp-desc-body h2:first-child { margin-top: 0; }

  .pdp-desc-body h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--green);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 32px 0 14px;
  }

  .pdp-desc-body p {
    font-size: 15px;
    color: #4B5563;
    line-height: 1.8;
    margin: 0 0 16px;
  }

  .pdp-desc-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .pdp-desc-body ul li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #F8F9F7;
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 14px;
    color: #374151;
    line-height: 1.5;
  }
  .pdp-desc-body ul li::before {
    content: '✓';
    color: var(--green);
    font-weight: 700;
    font-size: 15px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pdp-desc-body blockquote {
    background: #F0F7EF;
    border-left: 4px solid var(--green);
    border-radius: 0 12px 12px 0;
    padding: 20px 24px;
    margin: 24px 0;
    font-style: italic;
    color: #374151;
    font-size: 15px;
    line-height: 1.7;
  }
  .pdp-desc-body blockquote p { margin: 0; color: #374151; }

  .pdp-desc-body strong { color: var(--dark); font-weight: 700; }

  @media (max-width: 768px) {
    .pdp-wrap { grid-template-columns: 1fr; gap: 32px; }
    .pdp-gallery__main { position: static; }
    .pdp-info__title { font-size: 22px; }
    .pdp-info__price { font-size: 26px; }
    .pdp-desc-body ul { grid-template-columns: 1fr; }
  }
</style>

<div class="pdp-breadcrumb">
  <a href="{{ routes.root_url }}">← Back to Shop</a>
</div>

<div class="pdp-wrap">
  <div class="pdp-gallery">
    <div class="pdp-gallery__main">
      {%- if product.featured_image -%}
        <img id="mainProductImage" class="pdp-gallery__main-img" src="{{ product.featured_image | image_url: width: 1600 }}" alt="{{ product.title }}" loading="eager">
      {%- else -%}
        <div class="pdp-gallery__placeholder">🐾</div>
      {%- endif -%}
    </div>
    {%- if product.images.size > 1 -%}
      <div class="pdp-gallery__thumbs">
        {%- for image in product.images limit: 6 -%}
          <div class="pdp-gallery__thumb {% if forloop.first %}is-active{% endif %}" data-image-url="{{ image | image_url: width: 1600 }}" data-image-id="{{ image.id }}">
            <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title }}" loading="lazy">
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="pdp-info">
    <div class="pdp-info__category">{{ product.type | default: 'Pet Essentials' }}</div>
    <h1 class="pdp-info__title">{{ product.title }}</h1>

    {%- assign pdp_star_seed = product.id | modulo: 13 -%}
    {%- if pdp_star_seed < 3 -%}{%- assign pdp_rating = "4.6" -%}
    {%- elsif pdp_star_seed < 7 -%}{%- assign pdp_rating = "4.7" -%}
    {%- elsif pdp_star_seed < 10 -%}{%- assign pdp_rating = "4.8" -%}
    {%- else -%}{%- assign pdp_rating = "4.9" -%}
    {%- endif -%}
    {%- assign pdp_count = product.id | modulo: 179 | plus: 150 -%}
    <div class="pdp-info__stars">
      <span class="pdp-info__stars-icons">★★★★★</span>
      <span class="pdp-info__stars-label">{{ pdp_rating }} ({{ pdp_count }} reviews)</span>
    </div>

    <div class="pdp-info__price-row">
      <span class="pdp-info__price" id="price-display">{{ current_variant.price | money }}</span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
        <span class="pdp-info__compare" id="compare-price">{{ current_variant.compare_at_price | money }}</span>
        <span class="pdp-info__badge">Save {{ save_pct }}%</span>
      {%- else -%}
        <span class="pdp-info__compare" id="compare-price" style="display:none;"></span>
      {%- endif -%}
    </div>
    {%- if current_variant.compare_at_price > current_variant.price -%}
      {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
      <div class="pdp-info__savings" id="savings-display">🎉 You save {{ savings | money }}!</div>
    {%- else -%}
      <div class="pdp-info__savings" id="savings-display" style="display:none;"></div>
    {%- endif -%}

    {%- unless product.has_only_default_variant -%}
      <div class="pdp-info__variants">
        {%- for option in product.options_with_values -%}
          {%- assign option_lower = option.name | downcase -%}
          {%- assign is_bundle = false -%}
          {%- if option_lower contains 'pack' or option_lower contains 'bundle' or option_lower contains 'quantity' or option_lower contains 'size' -%}
            {%- assign is_bundle = true -%}
          {%- endif -%}
          <div class="pdp-info__variant-group">
            <div class="pdp-info__option-label">{{ option.name }}</div>
            {%- if is_bundle -%}
              <div style="display:flex;flex-direction:column;gap:10px;">
                {%- for value in option.values -%}
                  {%- assign opt_pos = option.position | minus: 1 -%}
                  {%- assign bundle_price = nil -%}
                  {%- assign bundle_compare = nil -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.options[opt_pos] == value -%}
                      {%- assign bundle_price = variant.price -%}
                      {%- assign bundle_compare = variant.compare_at_price -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- assign bsave_pct = 0 -%}
                  {%- if bundle_compare > bundle_price -%}
                    {%- assign bsave_pct = bundle_compare | minus: bundle_price | times: 100 | divided_by: bundle_compare -%}
                  {%- endif -%}
                  <button type="button" class="variant-btn bundle-card {% if option.selected_value == value %}bundle-card--active{% endif %}"
                    data-option-position="{{ option.position }}" data-value="{{ value }}"
                    style="display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border:2px solid {% if option.selected_value == value %}var(--green){% else %}var(--border){% endif %};border-radius:12px;background:{% if option.selected_value == value %}var(--green-light){% else %}white{% endif %};cursor:pointer;font-family:var(--font-body);width:100%;text-align:left;transition:all 0.2s;">
                    <div style="display:flex;align-items:center;gap:12px;">
                      <div style="width:18px;height:18px;border-radius:50%;border:2px solid {% if option.selected_value == value %}var(--green){% else %}var(--border){% endif %};background:{% if option.selected_value == value %}var(--green){% else %}white{% endif %};flex-shrink:0;"></div>
                      <div>
                        <div style="font-weight:600;font-size:14px;color:var(--dark);">{{ value }}</div>
                        {%- if bsave_pct > 0 -%}<div style="font-size:12px;color:var(--green);font-weight:600;">SAVE {{ bsave_pct }}%</div>{%- endif -%}
                      </div>
                    </div>
                    <div style="text-align:right;">
                      {%- if bundle_price -%}
                        <div style="font-weight:700;font-size:16px;color:var(--dark);">{{ bundle_price | money }}</div>
                        {%- if bundle_compare > bundle_price -%}<div style="font-size:12px;color:var(--muted);text-decoration:line-through;">{{ bundle_compare | money }}</div>{%- endif -%}
                      {%- endif -%}
                    </div>
                  </button>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div style="display:flex;flex-wrap:wrap;gap:8px;">
                {%- for value in option.values -%}
                  <button type="button" class="variant-btn {% if option.selected_value == value %}variant-btn--active{% endif %}"
                    data-option-position="{{ option.position }}" data-value="{{ value }}"
                    style="padding:8px 18px;border:2px solid {% if option.selected_value == value %}var(--green){% else %}var(--border){% endif %};border-radius:50px;font-size:13px;font-family:var(--font-body);cursor:pointer;background:{% if option.selected_value == value %}var(--green){% else %}white{% endif %};color:{% if option.selected_value == value %}white{% else %}var(--dark){% endif %};transition:all 0.2s;">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endunless -%}

    {%- form 'product', product, id: 'product-form' -%}
      <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">
      <div class="pdp-atc">
        <button type="submit" class="pdp-atc__btn" id="add-to-cart-btn" {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}🛒 Add to Cart{%- else -%}Sold Out{%- endif -%}
        </button>
      </div>
    {%- endform -%}

    <div class="pdp-trust">
      <div class="pdp-trust__item">
        <span class="pdp-trust__icon">🚚</span>
        <span>Fast US Shipping</span>
      </div>
      <div class="pdp-trust__item">
        <span class="pdp-trust__icon">🔄</span>
        <span>30-Day Returns</span>
      </div>
      <div class="pdp-trust__item">
        <span class="pdp-trust__icon">🔒</span>
        <span>Secure Checkout</span>
      </div>
    </div>
  </div>
</div>

{%- if product.description != blank -%}
  <div class="pdp-desc-section">
    <hr class="pdp-desc-divider">
    <div class="pdp-desc-body">
      {{ product.description }}
    </div>
  </div>
{%- endif -%}

<script>
  var productVariants = {{ product.variants | json }};
  var selectedOptions = [
    {%- for option in product.options_with_values -%}
      "{{ option.selected_value }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  function findVariant() {
    return productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOptions[i]; });
    });
  }

  function updateProduct(variant) {
    if (!variant) return;
    document.getElementById('variant-id').value = variant.id;

    if (variant.featured_image) {
      var matchThumb = document.querySelector('.pdp-gallery__thumb[data-image-id="' + variant.featured_image.id + '"]');
      if (matchThumb) {
        var imgEl = document.getElementById('mainProductImage');
        if (imgEl) imgEl.src = matchThumb.dataset.imageUrl;
        document.querySelectorAll('.pdp-gallery__thumb').forEach(function(t) { t.classList.remove('is-active'); });
        matchThumb.classList.add('is-active');
      }
    }

    var price = (variant.price / 100).toLocaleString('en-US', {style:'currency', currency:'USD'});
    document.getElementById('price-display').textContent = price;
    var compareEl = document.getElementById('compare-price');
    var savingsEl = document.getElementById('savings-display');
    if (variant.compare_at_price > variant.price) {
      var comparePrice = (variant.compare_at_price / 100).toLocaleString('en-US', {style:'currency', currency:'USD'});
      compareEl.textContent = comparePrice;
      compareEl.style.display = 'inline';
      var savings = ((variant.compare_at_price - variant.price) / 100).toLocaleString('en-US', {style:'currency', currency:'USD'});
      savingsEl.textContent = '🎉 You save ' + savings + '!';
      savingsEl.style.display = 'block';
    } else {
      compareEl.style.display = 'none';
      savingsEl.style.display = 'none';
    }
    var btn = document.getElementById('add-to-cart-btn');
    if (variant.available) {
      btn.disabled = false;
      btn.textContent = '🛒 Add to Cart';
    } else {
      btn.disabled = true;
      btn.textContent = 'Sold Out';
    }
  }

  document.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var position = parseInt(this.dataset.optionPosition) - 1;
      selectedOptions[position] = this.dataset.value;
      document.querySelectorAll('.variant-btn[data-option-position="' + this.dataset.optionPosition + '"]').forEach(function(b) {
        b.style.background = 'white';
        b.style.color = 'var(--dark)';
        b.style.borderColor = 'var(--border)';
      });
      this.style.background = 'var(--green)';
      this.style.color = 'white';
      this.style.borderColor = 'var(--green)';
      var variant = findVariant();
      if (variant) updateProduct(variant);
    });
  });

  document.querySelectorAll('.pdp-gallery__thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var url = this.dataset.imageUrl;
      if (url) document.getElementById('mainProductImage').src = url;
      document.querySelectorAll('.pdp-gallery__thumb').forEach(function(t) { t.classList.remove('is-active'); });
      this.classList.add('is-active');
    });
  });
</script>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
