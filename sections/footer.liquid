<footer class="site-footer">
  <div class="footer__inner">
    <div class="footer__grid">
      <div>
        <div class="footer__logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 140 }}" alt="{{ shop.name }}">
          {%- else -%}
            🐾 {{ shop.name }}
          {%- endif -%}
        </div>
        <p class="footer__desc">{{ section.settings.description }}</p>
        <div class="footer__socials">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" class="footer__social" aria-label="Instagram">📸</a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" class="footer__social" aria-label="Facebook">📘</a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" class="footer__social" aria-label="TikTok">🎵</a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
            <a href="{{ section.settings.youtube }}" class="footer__social" aria-label="YouTube">▶️</a>
          {%- endif -%}
        </div>
      </div>

      <div>
        <div class="footer__heading">Quick Links</div>
        <ul class="footer__links">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="/collections/all">Catalog</a></li>
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__heading">Our Policies</div>
        <ul class="footer__links">
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__heading">Customer Service</div>
        <ul class="footer__links">
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="mailto:support@pawfield.co">support@pawfield.co</a></li>
          <li><span style="color:var(--muted);font-size:13px;">Mon–Fri, 9am–6pm EST</span></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. Made with ♥ for pets.</div>
      <div class="footer__payments">
        <span class="footer__payment">VISA</span>
        <span class="footer__payment">Mastercard</span>
        <span class="footer__payment">PayPal</span>
        <span class="footer__payment">Apple Pay</span>
        <span class="footer__payment">Shop Pay</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "textarea", "id": "description", "label": "Store description", "default": "Premium pet essentials for dogs and cats. We believe every pet deserves the best — and every owner deserves products that actually work." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },
    { "type": "text", "id": "heading_1", "label": "Column 1 heading", "default": "Shop" },
    { "type": "link_list", "id": "menu_1", "label": "Column 1 menu" },
    { "type": "text", "id": "heading_2", "label": "Column 2 heading", "default": "Support" },
    { "type": "link_list", "id": "menu_2", "label": "Column 2 menu" },
    { "type": "text", "id": "heading_3", "label": "Column 3 heading", "default": "Company" },
    { "type": "link_list", "id": "menu_3", "label": "Column 3 menu" }
  ]
}
{% endschema %}
