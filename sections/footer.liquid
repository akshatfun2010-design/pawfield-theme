<style>
  .site-footer {
    background: #fff;
    border-top: 1px solid #e8ede7;
    padding: 60px 24px 32px;
  }
  .site-footer__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 48px;
  }
  .site-footer__heading {
    font-size: 15px;
    font-weight: 700;
    color: #1c1c1c;
    margin-bottom: 16px;
    text-align: center;
  }
  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
  }
  .site-footer__links li { margin-bottom: 10px; }
  .site-footer__links a {
    font-size: 14px;
    color: #6B7280;
    text-decoration: none;
    transition: color 0.2s;
  }
  .site-footer__links a:hover { color: #3A6B35; }
  .site-footer__service-text {
    font-size: 14px;
    color: #374151;
    text-align: center;
    line-height: 1.6;
    margin-bottom: 8px;
  }
  .site-footer__email {
    display: block;
    font-size: 14px;
    color: #3A6B35;
    text-align: center;
    text-decoration: none;
  }
  .site-footer__newsletter-text {
    font-size: 14px;
    color: #374151;
    text-align: center;
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .site-footer__form { display: flex; flex-direction: column; gap: 8px; }
  .site-footer__input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    font-size: 14px;
    color: #374151;
    box-sizing: border-box;
    outline: none;
  }
  .site-footer__input:focus { border-color: #3A6B35; }
  .site-footer__subscribe {
    width: 100%;
    padding: 11px;
    background: #3A6B35;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .site-footer__subscribe:hover { opacity: 0.88; }
  .site-footer__bottom {
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid #e8ede7;
    text-align: center;
    font-size: 13px;
    color: #9CA3AF;
  }
  @media (max-width: 768px) {
    .site-footer__grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .site-footer { padding: 40px 16px 24px; }
  }
  @media (max-width: 480px) {
    .site-footer__grid { grid-template-columns: 1fr; }
  }
</style>

<footer class="site-footer">
  <div class="site-footer__grid">

    <div>
      <div class="site-footer__heading">About PawField</div>
      <ul class="site-footer__links">
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="/pages/contact">Contact</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
      </ul>
    </div>

    <div>
      <div class="site-footer__heading">Our Policies</div>
      <ul class="site-footer__links">
        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
        <li><a href="/policies/refund-policy">Refund Policy</a></li>
        <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        <li><a href="/policies/terms-of-service">Terms of Service</a></li>
      </ul>
    </div>

    <div>
      <div class="site-footer__heading">Customer Service Hours</div>
      <p class="site-footer__service-text">Mon–Fri, 9am–6pm PST. We respond within 24 hours.</p>
      <a href="mailto:support@pawfield.co" class="site-footer__email">support@pawfield.co</a>
    </div>

    <div>
      <div class="site-footer__heading">Newsletter</div>
      <p class="site-footer__newsletter-text">Would you like to receive news and exclusive offers?</p>
      <form class="site-footer__form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input class="site-footer__input" type="email" name="contact[email]" placeholder="Enter your email" required>
        <button type="submit" class="site-footer__subscribe">Subscribe</button>
      </form>
    </div>

  </div>

  <div class="site-footer__bottom">
    © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
