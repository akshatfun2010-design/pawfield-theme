<div class="trust-badges">
  <div class="trust-badges__grid">
    {%- for i in (1..4) -%}
      {%- assign icon_key = 'badge_' | append: i | append: '_icon' -%}
      {%- assign title_key = 'badge_' | append: i | append: '_title' -%}
      {%- assign text_key = 'badge_' | append: i | append: '_text' -%}
      <div class="trust-badge">
        <div class="trust-badge__icon">{{ section.settings[icon_key] }}</div>
        <div>
          <div class="trust-badge__title">{{ section.settings[title_key] }}</div>
          <div class="trust-badge__text">{{ section.settings[text_key] }}</div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    { "type": "text", "id": "badge_1_icon", "label": "Badge 1 icon (emoji)", "default": "🚚" },
    { "type": "text", "id": "badge_1_title", "label": "Badge 1 title", "default": "Fast US Delivery" },
    { "type": "text", "id": "badge_1_text", "label": "Badge 1 text", "default": "Arrives in 6–12 business days." },
    { "type": "text", "id": "badge_2_icon", "label": "Badge 2 icon (emoji)", "default": "🔄" },
    { "type": "text", "id": "badge_2_title", "label": "Badge 2 title", "default": "30-Day Returns" },
    { "type": "text", "id": "badge_2_text", "label": "Badge 2 text", "default": "Not happy? Full refund within 30 days. No questions asked." },
    { "type": "text", "id": "badge_3_icon", "label": "Badge 3 icon (emoji)", "default": "🐾" },
    { "type": "text", "id": "badge_3_title", "label": "Badge 3 title", "default": "Carefully Curated" },
    { "type": "text", "id": "badge_3_text", "label": "Badge 3 text", "default": "Every product hand-picked for quality and safety." },
    { "type": "text", "id": "badge_4_icon", "label": "Badge 4 icon (emoji)", "default": "🔒" },
    { "type": "text", "id": "badge_4_title", "label": "Badge 4 title", "default": "Secure Checkout" },
    { "type": "text", "id": "badge_4_text", "label": "Badge 4 text", "default": "SSL encrypted. Your payment info is always safe." }
  ],
  "presets": [{ "name": "Trust Badges" }]
}
{% endschema %}
