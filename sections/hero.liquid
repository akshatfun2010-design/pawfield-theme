<section class="hero">
  <div class="hero__bg">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}" width="1920" height="800" loading="eager">
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1920&q=80" alt="Happy dog" width="1920" height="800" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <div class="hero__inner">
      {%- if section.settings.badge != blank -%}
        <div class="hero__badge">⭐ {{ section.settings.badge }}</div>
      {%- endif -%}

      <h1 class="hero__title">
        {{ section.settings.heading | replace: section.settings.accent_word, '<span>' | append: '</span>' }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="hero__text">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="hero__btns">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">{{ section.settings.button_label }} →</a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank -%}
          <a href="{{ section.settings.button_2_url | default: '/collections/all/smart-tech' }}" class="btn btn--secondary btn--lg" style="color:white;border-color:rgba(255,255,255,0.6);">{{ section.settings.button_2_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_stats -%}
        <div class="hero__stats">
          <div>
            <div class="hero__stat-num">{{ section.settings.stat_1_num }}</div>
            <div class="hero__stat-label">{{ section.settings.stat_1_label }}</div>
          </div>
          <div>
            <div class="hero__stat-num">{{ section.settings.stat_2_num }}</div>
            <div class="hero__stat-label">{{ section.settings.stat_2_label }}</div>
          </div>
          <div>
            <div class="hero__stat-num">{{ section.settings.stat_3_num }}</div>
            <div class="hero__stat-label">{{ section.settings.stat_3_label }}</div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "badge", "label": "Badge text", "default": "Trusted by 12,000+ Pet Owners" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Your Pet Deserves the Very Best." },
    { "type": "text", "id": "accent_word", "label": "Word to accent (green color)", "default": "Very Best." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Hand-picked premium essentials for dogs and cats — tested, curated, and delivered straight to your door." },
    { "type": "text", "id": "button_label", "label": "Button 1 label", "default": "Shop Best Sellers" },
    { "type": "url", "id": "button_url", "label": "Button 1 URL" },
    { "type": "text", "id": "button_2_label", "label": "Button 2 label", "default": "🤖 View Smart Tech" },
    { "type": "url", "id": "button_2_url", "label": "Button 2 URL" },
    { "type": "checkbox", "id": "show_stats", "label": "Show stats", "default": true },
    { "type": "text", "id": "stat_1_num", "label": "Stat 1 number", "default": "12K+" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Happy Customers" },
    { "type": "text", "id": "stat_2_num", "label": "Stat 2 number", "default": "4.9★" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Average Rating" },
    { "type": "text", "id": "stat_3_num", "label": "Stat 3 number", "default": "30-Day" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Money-Back Guarantee" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
