{%- assign collection = collections[section.settings.collection] -%}
{%- assign best_seller_products = collections.all.products | where: 'available', true -%}

<section class="section section--{{ section.settings.background }}" id="best-sellers" data-section-id="{{ section.id }}">
  <div class="section__inner">
    <div class="section__header-row">
      <div>
        {%- if section.settings.tag != blank -%}
          <div class="section__tag">{{ section.settings.tag }}</div>
        {%- endif -%}
        <h2 class="section__title">{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="section__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="view-all">View all →</a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_filters -%}
      <div class="filter-pills">
        <button class="filter-pill is-active" data-filter="all">🐾 All Pets</button>
        <button class="filter-pill" data-filter="dog">🐕 Dogs</button>
        <button class="filter-pill" data-filter="cat">🐈 Cats</button>
        <button class="filter-pill" data-filter="smart tech">🤖 Smart Tech</button>
        <button class="filter-pill" data-filter="grooming">✂️ Grooming</button>
        <button class="filter-pill" data-filter="bed">🛏️ Beds</button>
      </div>

      <div class="product-grid" id="product-grid-{{ section.id }}">
        {%- assign shown = 0 -%}
        {%- for product in collections.all.products -%}
          {%- if product.tags contains 'best-seller' and shown < section.settings.products_to_show -%}
            <div class="product-card-wrapper" data-tags="{{ product.tags | join: ',' | downcase }}">
              {%- render 'product-card', product: product -%}
            </div>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}

      <div class="product-grid" id="product-grid-{{ section.id }}">
        {%- assign shown = 0 -%}
        {%- for product in collections.all.products -%}
          {%- if shown < section.settings.products_to_show -%}
            <div class="product-card-wrapper" data-tags="{{ product.tags | join: ',' | downcase }}">
              {%- render 'product-card', product: product -%}
            </div>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    function filterProducts(filter) {
      section.querySelectorAll('.product-card-wrapper').forEach(function(card) {
        var tags = card.dataset.tags || '';
        var tagList = tags.split(',').map(function(t){ return t.trim().toLowerCase(); });
        var filterAlt = filter.replace(' ', '-').replace('-', ' ');
        var matches = filter === 'all' || tagList.some(function(t){
          return t === filter || t === filter + 's' || t + 's' === filter || t === filterAlt || t === filterAlt + 's' || t + 's' === filterAlt;
        });
        card.style.display = matches ? '' : 'none';
      });
    }

    section.querySelectorAll('.filter-pill[data-filter]').forEach(function(pill) {
      pill.addEventListener('click', function() {
        var filter = this.dataset.filter;
        section.querySelectorAll('.filter-pill[data-filter]').forEach(function(p) { p.classList.remove('is-active'); });
        this.classList.add('is-active');
        filterProducts(filter);
      });
    });

    section.querySelectorAll('.sidebar-cat').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = this.dataset.filter;
        section.querySelectorAll('.sidebar-cat').forEach(function(b) {
          b.style.background = 'transparent';
          b.style.color = 'var(--dark)';
        });
        this.style.background = 'var(--green)';
        this.style.color = 'white';
        section.querySelectorAll('.filter-pill[data-filter]').forEach(function(p) { p.classList.remove('is-active'); });
        var matchingPill = section.querySelector('.filter-pill[data-filter="' + filter + '"]');
        if (matchingPill) matchingPill.classList.add('is-active');
        filterProducts(filter);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "tag", "label": "Tag label", "default": "🔥 Most Popular" },
    { "type": "text", "id": "title", "label": "Section title", "default": "Best Sellers" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Our top-rated products loved by thousands of pet parents every month." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 4, "label": "Products to show" },
    { "type": "select", "id": "background", "label": "Background", "options": [{"value":"cream","label":"Cream"},{"value":"white","label":"White"}], "default": "cream" },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter pills", "default": true }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
