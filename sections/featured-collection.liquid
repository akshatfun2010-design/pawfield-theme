{%- assign collection = collections[section.settings.collection] -%}

<section class="section section--{{ section.settings.background }}">
  <div class="section__inner">
    <div class="section__header-row">
      <div>
        {%- if section.settings.tag != blank -%}
          <div class="section__tag">{{ section.settings.tag }}</div>
        {%- endif -%}
        <h2 class="section__title">{{ section.settings.title }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="section__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="view-all">View all →</a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_filters -%}
      <div style="display:flex;gap:32px;align-items:flex-start;">
        <div style="min-width:160px;background:white;border:1px solid var(--border);border-radius:16px;padding:20px;position:sticky;top:100px;">
          <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:14px;">Categories</div>
          <div style="display:flex;flex-direction:column;gap:4px;">
            <button class="sidebar-cat is-active" data-filter="all" style="text-align:left;padding:8px 12px;border:none;background:var(--green);color:white;border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">🐾 All Pets</button>
            <button class="sidebar-cat" data-filter="dog" style="text-align:left;padding:8px 12px;border:none;background:transparent;color:var(--dark);border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">🐕 Dogs</button>
            <button class="sidebar-cat" data-filter="cat" style="text-align:left;padding:8px 12px;border:none;background:transparent;color:var(--dark);border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">🐈 Cats</button>
            <button class="sidebar-cat" data-filter="smart tech" style="text-align:left;padding:8px 12px;border:none;background:transparent;color:var(--dark);border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">🤖 Smart Tech</button>
            <button class="sidebar-cat" data-filter="grooming" style="text-align:left;padding:8px 12px;border:none;background:transparent;color:var(--dark);border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">✂️ Grooming</button>
            <button class="sidebar-cat" data-filter="bed" style="text-align:left;padding:8px 12px;border:none;background:transparent;color:var(--dark);border-radius:8px;font-size:14px;cursor:pointer;font-family:var(--font-body);">🛏️ Beds</button>
          </div>
          <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border);">
            <a href="{{ routes.root_url }}" style="font-size:13px;color:var(--green);text-decoration:none;">← Home</a>
          </div>
        </div>
        <div style="flex:1;">
      <div class="filter-pills">
        <button class="filter-pill is-active" data-filter="all">🐾 All Pets</button>
        <button class="filter-pill" data-filter="dog">🐕 Dogs</button>
        <button class="filter-pill" data-filter="cat">🐈 Cats</button>
        <button class="filter-pill" data-filter="smart tech">🤖 Smart Tech</button>
        <button class="filter-pill" data-filter="grooming">✂️ Grooming</button>
        <button class="filter-pill" data-filter="bed">🛏️ Beds</button>
      </div>
    {%- endif -%}

    <div class="product-grid" id="product-grid-{{ section.id }}">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="product-card-wrapper" data-tags="{{ product.tags | join: ',' | downcase }}">
            {%- render 'product-card', product: product -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="product-card-wrapper" data-tags="all"><div class="product-card">
            <div class="product-card__image" style="background:var(--green-light);display:flex;align-items:center;justify-content:center;aspect-ratio:1;font-size:60px;">🐾</div>
            <div class="product-card__info">
              <div class="product-card__category">Pet Essentials</div>
              <div class="product-card__title">Add your products from CJDropshipping</div>
              <div class="product-card__stars">
                <span class="product-card__stars-icons">★★★★★</span>
                <span class="product-card__review-count">(0 reviews)</span>
              </div>
              <div class="product-card__footer">
                <div><span class="product-card__price">$89</span></div>
                <button class="product-card__add-btn">+</button>
              </div>
            </div>
          </div></div>
        {%- endfor -%}
      {%- endif -%}
    </div>
        </div><!-- end flex:1 -->
      </div><!-- end sidebar flex -->
    {%- endif -%}
  </div>
</section>

<script>
  document.querySelectorAll('.filter-pill[data-filter]').forEach(function(pill) {
    pill.addEventListener('click', function() {
      var filter = this.dataset.filter;
      document.querySelectorAll('.filter-pill[data-filter]').forEach(function(p) { p.classList.remove('is-active'); });
      this.classList.add('is-active');
      document.querySelectorAll('#product-grid-{{ section.id }} .product-card-wrapper').forEach(function(card) {
        var tags = card.dataset.tags || '';
        var tagList = tags.split(',').map(function(t){ return t.trim().toLowerCase(); });
        var filterAlt = filter.replace(' ', '-').replace('-', ' ');
        var matches = filter === 'all' || tagList.some(function(t){
          return t === filter || t === filter + 's' || t + 's' === filter || t === filterAlt || t === filterAlt + 's' || t + 's' === filterAlt;
        });
        if (matches) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }

      });
    });
  });

  document.querySelectorAll('.sidebar-cat').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = this.dataset.filter;
      document.querySelectorAll('.sidebar-cat').forEach(function(b) {
        b.style.background = 'transparent';
        b.style.color = 'var(--dark)';
      });
      this.style.background = 'var(--green)';
      this.style.color = 'white';
      document.querySelectorAll('.filter-pill[data-filter]').forEach(function(p) { p.classList.remove('is-active'); });
      var matchingPill = document.querySelector('.filter-pill[data-filter="' + filter + '"]');
      if (matchingPill) matchingPill.classList.add('is-active');
      document.querySelectorAll('#product-grid-{{ section.id }} .product-card-wrapper').forEach(function(card) {
        var tags = card.dataset.tags || '';
        var tagList = tags.split(',').map(function(t){ return t.trim().toLowerCase(); });
        var filterAlt = filter.replace(' ', '-').replace('-', ' ');
        var matches = filter === 'all' || tagList.some(function(t){
          return t === filter || t === filter + 's' || t + 's' === filter || t === filterAlt || t === filterAlt + 's' || t + 's' === filterAlt;
        });
        card.style.display = matches ? '' : 'none';
      });
    });
  });
</script>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text", "id": "tag", "label": "Tag label", "default": "🔥 Most Popular" },
    { "type": "text", "id": "title", "label": "Section title", "default": "Best Sellers" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Our top-rated products loved by thousands of pet parents every month." },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 4, "label": "Products to show" },
    { "type": "select", "id": "background", "label": "Background", "options": [{"value":"cream","label":"Cream"},{"value":"white","label":"White"}], "default": "cream" },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter pills", "default": true }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
