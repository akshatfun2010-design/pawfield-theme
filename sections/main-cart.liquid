<style>
  .shipping-bar {
    background: #F5F7F4;
    border: 1.5px solid #D4E8D0;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 24px;
  }
  .shipping-bar__message {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    margin-bottom: 10px;
    text-align: center;
  }
  .shipping-bar__message.unlocked {
    color: #3A6B35;
    font-weight: 600;
    font-size: 15px;
  }
  .shipping-bar__track {
    background: #E5E7EB;
    border-radius: 50px;
    height: 8px;
    overflow: hidden;
  }
  .shipping-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, #3A6B35, #5A9E52);
    border-radius: 50px;
    transition: width 0.4s ease;
  }
  @media (max-width: 768px) {
    .cart-page { padding: 20px 16px; }
    .cart-page__title { font-size: 24px; margin-bottom: 20px; }
    .cart-item { grid-template-columns: 70px 1fr !important; gap: 12px !important; }
    .cart-item__price-col { grid-column: 1 / -1; display: flex; justify-content: space-between; align-items: center; }
    .cart-item__price { font-size: 16px; }
    .cart-summary { padding: 16px; }
    .cart-summary__title { font-size: 18px; margin-bottom: 14px; }
    .cart-summary__total { font-size: 17px; }
    .empty-cart-emoji { font-size: 56px !important; }
    .empty-cart-title { font-size: 24px !important; }
  }
</style>

<div class="cart-page">
  <a href="{{ routes.root_url }}" style="display:inline-flex;align-items:center;gap:6px;color:var(--green);font-size:14px;margin-bottom:20px;text-decoration:none;">← Continue Shopping</a>
  <h1 class="cart-page__title">Your Cart 🛒</h1>
  {%- if cart.item_count > 0 -%}
    {%- assign threshold = 6000 -%}
    {%- assign remaining = threshold | minus: cart.total_price -%}
    {%- assign progress = cart.total_price | times: 100 | divided_by: threshold -%}
    {%- if progress > 100 -%}{%- assign progress = 100 -%}{%- endif -%}
    <div class="shipping-bar" id="shipping-bar">
      {%- if cart.total_price >= threshold -%}
        <div class="shipping-bar__message unlocked" id="shipping-bar-msg">You've unlocked free shipping! 🎉</div>
      {%- else -%}
        <div class="shipping-bar__message" id="shipping-bar-msg">You're <strong>{{ remaining | money }}</strong> away from free shipping!</div>
      {%- endif -%}
      <div class="shipping-bar__track">
        <div class="shipping-bar__fill" id="shipping-bar-fill" style="width:{{ progress }}%;"></div>
      </div>
    </div>

    <div id="cart-items">
      {%- for item in cart.items -%}
        <div class="cart-item" id="cart-item-{{ item.key | replace: ':', '-' }}">
          <div class="cart-item__image">
            <a href="{{ item.url }}">
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" width="100" height="100">
            </a>
          </div>
          <div style="flex:1;">
            <div class="cart-item__title">{{ item.product.title }}</div>
            {%- unless item.product.has_only_default_variant -%}
              <div style="font-size:13px;color:var(--muted);margin-bottom:8px;">{{ item.variant.title }}</div>
            {%- endunless -%}
            <div class="cart-item__qty">
              <button class="cart-item__qty-btn" type="button" onclick="changeQty('{{ item.key }}',-1)">−</button>
              <span class="cart-item__qty-num" id="qty-{{ item.key | replace: ':', '-' }}">{{ item.quantity }}</span>
              <button class="cart-item__qty-btn" type="button" onclick="changeQty('{{ item.key }}',1)">+</button>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:12px;">
            <div class="cart-item__price" id="price-{{ item.key | replace: ':', '-' }}">{{ item.final_line_price | money }}</div>
            <button onclick="updateCartItem('{{ item.key }}', 0)" style="font-size:12px;color:var(--muted);background:none;border:none;cursor:pointer;text-decoration:underline;">Remove</button>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="cart-summary" id="cart-summary">
      <h2 class="cart-summary__title">Order Summary</h2>
      <div class="cart-summary__line"><span>Subtotal</span><span id="cart-subtotal">{{ cart.total_price | money }}</span></div>
      <div class="cart-summary__line"><span>Shipping</span><span id="cart-shipping" style="font-weight:600;{%- if cart.total_price >= threshold -%}color:var(--green);{%- else -%}color:#374151;{%- endif -%}">{%- if cart.total_price >= threshold -%}FREE{%- else -%}$6.00{%- endif -%}</span></div>
      {%- if cart.total_price >= threshold -%}
        {%- assign display_total = cart.total_price -%}
      {%- else -%}
        {%- assign display_total = cart.total_price | plus: 600 -%}
      {%- endif -%}
      <div class="cart-summary__total"><span>Total</span><span id="cart-total">{{ display_total | money }}</span></div>
      <a href="/checkout" class="btn btn--primary" style="width:100%;justify-content:center;font-size:16px;padding:16px;display:flex;">Checkout Securely 🔒</a>
      <p style="text-align:center;font-size:13px;color:var(--muted);margin-top:12px;">🔄 30-day returns · 🚚 Fast US shipping</p>
    </div>
  {%- else -%}
    <div style="text-align:center;padding:60px 0;" id="empty-cart">
      <div style="font-size:80px;margin-bottom:20px;">🐾</div>
      <h2 style="font-family:var(--font-heading);font-size:32px;margin-bottom:12px;">Your cart is empty</h2>
      <p style="color:var(--muted);margin-bottom:28px;">Looks like you haven't added anything yet.</p>
      <a href="{{ routes.root_url }}" class="btn btn--primary">Shop Now →</a>
    </div>
  {%- endif -%}
</div>

<script>
  function fmt(cents) {
    return (Math.max(parseInt(cents) || 0, 0) / 100).toLocaleString('en-US', {style:'currency', currency:'USD'});
  }

  function changeQty(key, delta) {
    var safeKey = key.replace(':', '-');
    var qtyEl = document.getElementById('qty-' + safeKey);
    var current = parseInt(qtyEl ? qtyEl.textContent : '1') || 1;
    var next = Math.max(0, current + delta);
    updateCartItem(key, next);
  }

  function updateCartItem(key, quantity) {
    if (isNaN(quantity) || quantity < 0) return;
    fetch('/cart/change.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({id: key, quantity: quantity})
    })
    .then(function(r) { return r.json(); })
    .then(function(cart) {
      var countEl = document.getElementById('cart-count');
      if (countEl) countEl.textContent = cart.item_count;

      if (cart.item_count === 0) { location.reload(); return; }

      // Remove item from DOM if qty set to 0
      if (quantity === 0) {
        var itemEl = document.getElementById('cart-item-' + key.replace(':', '-'));
        if (itemEl) itemEl.remove();
      }

      // Update every item's qty and line price from the API response
      cart.items.forEach(function(item) {
        var sk = item.key.replace(':', '-');
        var q = document.getElementById('qty-' + sk);
        var p = document.getElementById('price-' + sk);
        if (q) q.textContent = item.quantity;
        if (p) p.textContent = fmt(item.final_line_price);
      });

      // Update order summary from fresh cart data
      var subtotal = parseInt(cart.total_price) || 0;
      var threshold = 6000;
      var shipping = subtotal >= threshold ? 0 : 600;

      var subtotalEl = document.getElementById('cart-subtotal');
      var totalEl = document.getElementById('cart-total');
      var shippingEl = document.getElementById('cart-shipping');
      if (subtotalEl) subtotalEl.textContent = fmt(subtotal);
      if (totalEl) totalEl.textContent = fmt(subtotal + shipping);
      if (shippingEl) {
        if (subtotal >= threshold) { shippingEl.textContent = 'FREE'; shippingEl.style.color = 'var(--green)'; }
        else { shippingEl.textContent = '$6.00'; shippingEl.style.color = '#374151'; }
      }

      // Update shipping progress bar
      var msgEl = document.getElementById('shipping-bar-msg');
      var fillEl = document.getElementById('shipping-bar-fill');
      if (msgEl && fillEl) {
        fillEl.style.width = Math.min(Math.round(subtotal / threshold * 100), 100) + '%';
        if (subtotal >= threshold) {
          msgEl.className = 'shipping-bar__message unlocked';
          msgEl.innerHTML = "You've unlocked free shipping! 🎉";
        } else {
          msgEl.className = 'shipping-bar__message';
          msgEl.innerHTML = "You're <strong>" + fmt(threshold - subtotal) + "</strong> away from free shipping!";
        }
      }
    });
  }
</script>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
