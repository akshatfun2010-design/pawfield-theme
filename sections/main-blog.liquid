<section class="section section--cream">
  <div class="section__inner">
    <div class="section__header">
      <div class="section__tag">📝 Pet Care Tips</div>
      <h1 class="section__title">{{ blog.title }}</h1>
    </div>
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <article class="blog-card">
          <a href="{{ article.url }}">
            {%- if article.image -%}
              <img class="blog-card__image" src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title }}" width="600" height="200" loading="lazy">
            {%- else -%}
              <div class="blog-card__image">🐾</div>
            {%- endif -%}
          </a>
          <div class="blog-card__info">
            <div class="blog-card__tag">{{ article.tags.first | default: 'Pet Care' }}</div>
            <h2 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            <div class="blog-card__meta">{{ article.published_at | date: '%B %d, %Y' }}</div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
