<style>
  .pf-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    width: 100%;
    z-index: 9999;
    background: #FAFAF6;
    border-bottom: 1px solid #E5E5E0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .pf-announce-bar {
    background: #3A6B35;
    color: white;
    text-align: center;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.3px;
  }
  .pf-nav-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .pf-logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-size: 21px;
    font-weight: 700;
    color: #3A6B35;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pf-logo-link img { height: 40px; width: auto; display: block; }
  .pf-nav-list {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }
  .pf-nav-list a {
    display: block;
    padding: 8px 14px;
    font-size: 15px;
    font-weight: 500;
    color: #1C1C1C;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
  }
  .pf-nav-list a:hover { background: #F0F4EF; color: #3A6B35; }
  .pf-header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .pf-cart-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    background: #3A6B35;
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.15s;
  }
  .pf-cart-btn:hover { background: #2D5A28; color: white; }
  .pf-cart-count {
    background: white;
    color: #3A6B35;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
  }
  .pf-burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    font-size: 22px;
    line-height: 1;
    color: #1C1C1C;
    flex-shrink: 0;
  }
  .pf-mobile-menu {
    display: none;
    flex-direction: column;
    background: #FAFAF6;
    border-top: 1px solid #F0F0EC;
  }
  .pf-mobile-menu.is-open { display: flex; }
  .pf-mobile-menu a {
    padding: 14px 24px;
    color: #1C1C1C;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    border-bottom: 1px solid #F0F0EC;
    transition: background 0.1s;
  }
  .pf-mobile-menu a:hover { background: #F5F7F4; color: #3A6B35; }

  @media (max-width: 768px) {
    .pf-announce-bar { font-size: 11px; padding: 7px 12px; }
    .pf-nav-list { display: none; }
    .pf-burger { display: block; }
    .pf-cart-label { display: none; }
  }
</style>

<header class="pf-header" id="pf-global-header">
  <div class="pf-announce-bar">🐾 Free shipping on orders over $60 &middot; Use PAWFIELD10 for 10% off</div>
  <div class="pf-nav-wrap">
    <a href="{{ routes.root_url }}" class="pf-logo-link">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" height="40" loading="eager">
      {%- else -%}
        🐾 {{ shop.name }}
      {%- endif -%}
    </a>
    <nav aria-label="Main navigation">
      <ul class="pf-nav-list">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><a href="/collections/all">Catalog</a></li>
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="/pages/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="pf-header-actions">
      <a href="{{ routes.cart_url }}" class="pf-cart-btn" aria-label="Cart">
        🛒 <span class="pf-cart-label">Cart</span>
        <span class="pf-cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>
      <button class="pf-burger" id="pfBurger" aria-label="Toggle menu" aria-expanded="false">☰</button>
    </div>
  </div>
  <nav class="pf-mobile-menu" id="pfMobileMenu" aria-label="Mobile navigation">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="/collections/all">Catalog</a>
    <a href="/pages/about-us">About Us</a>
    <a href="/pages/contact">Contact</a>
    <a href="{{ routes.cart_url }}">🛒 Cart ({{ cart.item_count }})</a>
  </nav>
</header>

<script>
  (function() {
    var burger = document.getElementById('pfBurger');
    var menu = document.getElementById('pfMobileMenu');
    if (burger && menu) {
      burger.addEventListener('click', function() {
        var open = menu.classList.toggle('is-open');
        burger.setAttribute('aria-expanded', open);
        burger.textContent = open ? '✕' : '☰';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
