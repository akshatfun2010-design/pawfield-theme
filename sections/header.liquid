<header class="site-header">
  <div class="header__wrapper">

    <nav aria-label="Main navigation">
      <ul class="header__nav">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><a href="/collections/all">Catalog</a></li>
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="{{ routes.account_url }}">Orders</a></li>
      </ul>
    </nav>

    <a href="{{ routes.root_url }}" class="header__logo header__logo--center">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="44">
      {%- else -%}
        🐾 {{ shop.name }}
      {%- endif -%}
    </a>

    <div class="header__icons">
      <a href="{{ routes.cart_url }}" class="header__cart-btn" aria-label="Cart" id="cart-btn">
        🛒 Cart
        <span class="header__cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>
      <button class="header__mobile-toggle" id="mobileToggle" aria-label="Toggle menu">☰</button>
    </div>

  </div>

  <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    <ul>
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><a href="/collections/all">Catalog</a></li>
      <li><a href="/pages/about-us">About Us</a></li>
      <li><a href="{{ routes.account_url }}">Orders</a></li>
      <li><a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a></li>
    </ul>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    }
  ]
}
{% endschema %}
