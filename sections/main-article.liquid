<article class="page-content" style="max-width:760px;">
  <div style="margin-bottom:32px;">
    <a href="{{ blog.url }}" style="color:var(--green);font-weight:600;font-size:14px;">← Back to {{ blog.title }}</a>
  </div>
  <div style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;font-weight:600;margin-bottom:12px;">{{ article.tags.first | default: 'Pet Care' }}</div>
  <h1 style="font-family:var(--font-heading);font-size:44px;line-height:1.2;margin-bottom:20px;">{{ article.title }}</h1>
  <div style="display:flex;align-items:center;gap:16px;margin-bottom:40px;padding-bottom:32px;border-bottom:1px solid var(--border);">
    <span style="font-size:13px;color:var(--muted);">By {{ article.author }}</span>
    <span style="color:var(--border);">·</span>
    <span style="font-size:13px;color:var(--muted);">{{ article.published_at | date: '%B %d, %Y' }}</span>
  </div>
  {%- if article.image -%}
    <img src="{{ article.image | image_url: width: 900 }}" alt="{{ article.title }}" style="width:100%;border-radius:var(--radius-lg);margin-bottom:40px;" loading="eager">
  {%- endif -%}
  <div style="font-size:17px;line-height:1.85;color:var(--muted);">{{ article.content }}</div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
