<section class="section section--{{ section.settings.background }}">
  <div class="section__inner">
    <div class="rich-text">
      <div class="rich-text__inner">
        {%- if section.settings.tag != blank -%}
          <div class="section__tag">{{ section.settings.tag }}</div>
        {%- endif -%}
        <h2 class="rich-text__title">{{ section.settings.title }}</h2>
        <p class="rich-text__text">{{ section.settings.text }}</p>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    { "type": "text", "id": "tag", "label": "Tag", "default": "💚 Our Story" },
    { "type": "textarea", "id": "title", "label": "Title", "default": "We Find It. You Love It. Your Pet Thrives." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "At Pawfield, we do the hard work of finding the best pet products on the market so you don't have to. Every item is hand-selected for quality, durability, and value. We partner with trusted suppliers worldwide to bring premium pet care to your doorstep — without the premium price tag." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "select", "id": "background", "label": "Background", "options": [{"value":"cream","label":"Cream"},{"value":"white","label":"White"}], "default": "white" }
  ],
  "presets": [{ "name": "Rich Text" }]
}
{% endschema %}
