<style>
  .rich-text-global-wrap {
    padding: {{ section.settings.padding_v }}px 24px;
    background: {{ section.settings.bg_color }};
  }
  .rich-text-global-card {
    max-width: 780px;
    margin: 0 auto;
    background: {{ section.settings.card_color }};
    border-radius: 20px;
    padding: 56px 48px;
    text-align: {{ section.settings.alignment }};
  }
  .rich-text-global-card h2 {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 34px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 16px;
  }
  .rich-text-global-card p {
    font-size: 16px;
    line-height: 1.75;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
    margin: 0 0 28px;
  }
  .rich-text-global-btn {
    display: inline-block;
    padding: 14px 32px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .rich-text-global-btn:hover { opacity: 0.85; }
  @media (max-width: 768px) {
    .rich-text-global-card { padding: 40px 24px; }
    .rich-text-global-card h2 { font-size: 26px; }
  }
</style>

<div class="rich-text-global-wrap">
  <div class="rich-text-global-card">
    {%- if section.settings.tag != blank -%}
      <div class="section__tag" style="margin-bottom:16px;">{{ section.settings.tag }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2>{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="rich-text-global-btn">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    { "type": "text", "id": "tag", "label": "Tag pill", "default": "" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Our Mission" },
    { "type": "textarea", "id": "text", "label": "Body text", "default": "To make premium pet care accessible to every pet parent — because your furry family members deserve nothing less than the best." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Our Collection →" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Page background", "default": "#f5f7f4" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#3A6B35" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "btn_bg", "label": "Button background", "default": "#ffffff" },
    { "type": "color", "id": "btn_text_color", "label": "Button text color", "default": "#3A6B35" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "alignment", "label": "Text alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range", "id": "padding_v", "label": "Vertical padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "Rich Text" }]
}
{% endschema %}
