<section class="section section--white">
  <div class="section__inner">
    <div class="section__header section__header--center">
      <div class="section__tag">⭐ Reviews</div>
      <h2 class="section__title">{{ section.settings.title }}</h2>
      <p class="section__subtitle">{{ section.settings.subtitle }}</p>
    </div>
    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ block.settings.avatar }}</div>
            <div>
              <div class="testimonial-card__name">{{ block.settings.name }}</div>
              <div class="testimonial-card__meta">{{ block.settings.meta }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "What Pet Parents Are Saying" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Real reviews from real pet parents." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Review text", "default": "The automatic feeder changed my life. My dog gets fed on schedule even when I'm stuck at work late. Setup was under 5 minutes!" },
        { "type": "text", "id": "name", "label": "Customer name", "default": "Sarah M." },
        { "type": "text", "id": "meta", "label": "Location / description", "default": "Dog mom of 2 · Texas" },
        { "type": "text", "id": "avatar", "label": "Avatar emoji", "default": "👩" }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "testimonial", "settings": { "text": "The automatic feeder changed my life. My dog gets fed on schedule even when I'm stuck at work. Setup was under 5 minutes and the app is super easy.", "name": "Sarah M.", "meta": "Dog mom of 2 · Texas", "avatar": "👩" }},
      { "type": "testimonial", "settings": { "text": "Bought the orthopedic bed for my 11-year-old lab who has hip problems. He sleeps so much better now. The quality blew me away for the price.", "name": "James R.", "meta": "Senior dog owner · Florida", "avatar": "👨" }},
      { "type": "testimonial", "settings": { "text": "The self-cleaning litter box is a GAME CHANGER. Shipped quickly, easy to set up, and my apartment finally smells normal again.", "name": "Priya K.", "meta": "Cat mom · New York", "avatar": "👩" }}
    ]
  }]
}
{% endschema %}
