<div id="announcementBar" class="announcement-bar" style="background: {{ section.settings.background_color }};">
  <div class="announcement-bar__wrapper">
    <p>{{ section.settings.text }}</p>
    <button id="announcementClose" class="announcement-bar__close" aria-label="Close">✕</button>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "🐾 Free shipping on orders over $60 · Use PAWFIELD10 for 10% off your first order"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#3A6B35"
    }
  ]
}
{% endschema %}
