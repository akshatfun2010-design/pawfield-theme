<header class="site-header">
  <div class="header__wrapper">

    <a href="{{ routes.root_url }}" class="header__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="44">
      {%- else -%}
        🐾 {{ shop.name }}
      {%- endif -%}
    </a>

    <nav aria-label="Main navigation">
      <ul class="header__nav">
        {%- for link in section.settings.menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="header__icons">
      {%- if section.settings.show_currency -%}
        <div class="currency-selector">
          <select onchange="this.form && this.form.submit()" aria-label="Currency">
            {%- for currency in localization.available_countries -%}
              <option value="{{ currency.iso_code }}" {% if localization.country.iso_code == currency.iso_code %}selected{% endif %}>
                {{ currency.currency.iso_code }} {{ currency.currency.symbol }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}

      <a href="{{ routes.search_url }}" class="header__icon-btn" aria-label="Search">🔍</a>
      <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">👤</a>
      <a href="{{ routes.cart_url }}" class="header__cart-btn" aria-label="Cart">
        🛒 Cart
        <span class="header__cart-count">{{ cart.item_count }}</span>
      </a>

      <button class="header__mobile-toggle" id="mobileToggle" aria-label="Toggle menu">☰</button>
    </div>

  </div>

  <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    <ul>
      {%- for link in section.settings.menu.links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
      <li><a href="{{ routes.search_url }}">Search</a></li>
      <li><a href="{{ routes.account_url }}">Account</a></li>
      <li><a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a></li>
    </ul>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    }
  ]
}
{% endschema %}
