<section class="section section--cream">
  <div class="section__inner">
    <div class="section__header">
      <h1 class="section__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="section__subtitle">{{ collection.description }}</p>
      {%- endif -%}
    </div>
    <div class="filter-pills">
      <button class="filter-pill is-active">All</button>
      <button class="filter-pill">🐕 Dogs</button>
      <button class="filter-pill">🐈 Cats</button>
      <button class="filter-pill">🤖 Smart Tech</button>
      <button class="filter-pill">🛏️ Beds</button>
    </div>
    <div class="product-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p>No products found.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
