{%- assign fake_compare = product.price | times: 10 | divided_by: 7 -%}
{%- assign star_seed = product.id | modulo: 13 -%}
{%- if star_seed < 3 -%}{%- assign fake_rating = "4.6" -%}
{%- elsif star_seed < 7 -%}{%- assign fake_rating = "4.7" -%}
{%- elsif star_seed < 10 -%}{%- assign fake_rating = "4.8" -%}
{%- else -%}{%- assign fake_rating = "4.9" -%}
{%- endif -%}
{%- assign fake_count = product.id | modulo: 179 | plus: 150 -%}
<div class="product-card">
  <div class="product-card__badge product-card__badge--red">30% OFF</div>

  <a href="{{ product.url }}">
    <div class="product-card__image">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" width="500" height="500" loading="lazy">
      {%- else -%}
        <span style="font-size:60px;">🐾</span>
      {%- endif -%}
    </div>
  </a>

  <button class="product-card__wishlist" aria-label="Add to wishlist">♡</button>

  <div class="product-card__info">
    {%- if product.type != blank -%}
      <div class="product-card__category">{{ product.type }}</div>
    {%- endif -%}
    <a href="{{ product.url }}">
      <div class="product-card__title">{{ product.title }}</div>
    </a>
    <div class="product-card__stars">
      <span class="product-card__stars-icons">★★★★★</span>
      <span class="product-card__review-count">{{ fake_rating }} ({{ fake_count }} reviews)</span>
    </div>
    <div class="product-card__footer">
      <div>
        <span class="product-card__original-price">{{ fake_compare | money }}</span>
        <span class="product-card__price">{{ product.price | money }}</span>
      </div>
      <button type="button" class="product-card__add-btn" aria-label="Add to cart" data-variant-id="{{ product.selected_or_first_available_variant.id }}" onclick="pawfieldAddToCart(this)">+</button>
    </div>
  </div>
</div>
