{% doc %}
  @prompt
    Create a custom announcement bar section that sits at the very top of the page. It should have a colored background bar with a customizable background color. The announcement message should be centered by default, with an optional scrolling/marquee effect that the merchant can toggle on or off. The merchant should be able to customize: the announcement message text, background color, text color, font size, and whether the marquee/scrolling effect is enabled. The section should be fixed or static at the top of the page and be fully responsive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    z-index: 100;
  }

  .ai-announcement-bar__container-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px 20px;
  }

  .ai-announcement-bar__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
  }

  .ai-announcement-bar__content-{{ ai_gen_id }}--centered {
    text-align: center;
  }

  .ai-announcement-bar__marquee-{{ ai_gen_id }} {
    display: flex;
    animation: ai-announcement-bar-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-announcement-bar__marquee-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    padding-right: 100px;
  }

  @keyframes ai-announcement-bar-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }} class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar__container-{{ ai_gen_id }}">
    {% if block.settings.enable_marquee %}
      <div class="ai-announcement-bar__content-{{ ai_gen_id }}">
        <div class="ai-announcement-bar__marquee-{{ ai_gen_id }}">
          <div class="ai-announcement-bar__marquee-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text }}
          </div>
          <div class="ai-announcement-bar__marquee-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text }}
          </div>
        </div>
      </div>
    {% else %}
      <p class="ai-announcement-bar__content-{{ ai_gen_id }} ai-announcement-bar__content-{{ ai_gen_id }}--centered">
        {{ block.settings.announcement_text }}
      </p>
    {% endif %}
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustMarqueeSpeed();
      }

      adjustMarqueeSpeed() {
        const marquee = this.querySelector('.ai-announcement-bar__marquee-{{ ai_gen_id }}');
        if (!marquee) return;

        const item = this.querySelector('.ai-announcement-bar__marquee-item-{{ ai_gen_id }}');
        if (!item) return;

        const itemWidth = item.offsetWidth;
        const containerWidth = this.offsetWidth;

        if (itemWidth < containerWidth) {
          marquee.style.justifyContent = 'center';
          marquee.style.animation = 'none';
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Welcome to our store! Free shipping on orders over $50"
    },
    {
      "type": "checkbox",
      "id": "enable_marquee",
      "label": "Enable scrolling effect",
      "default": false
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "s",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#3A6B35"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
