{% doc %}
  @prompt
    Add a sticky header effect so the navigation header stays fixed at the top of the page as the user scrolls down. The header should smoothly stick to the top without jumping or layout shifts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-header-{{ ai_gen_id }} {
    display: block;
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: {{ block.settings.background_color }};
    transition: box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .ai-sticky-header-{{ ai_gen_id }}.scrolled {
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    {% if block.settings.scrolled_background_color != blank %}
      background-color: {{ block.settings.scrolled_background_color }};
    {% endif %}
  }

  .ai-sticky-header__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .ai-sticky-header__logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.logo_size }}px;
    font-weight: 700;
  }

  .ai-sticky-header__logo-image-{{ ai_gen_id }} {
    height: {{ block.settings.logo_height }}px;
    width: auto;
  }

  .ai-sticky-header__nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.nav_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-sticky-header__nav-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.nav_font_size }}px;
    transition: color 0.2s ease;
  }

  .ai-sticky-header__nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-sticky-header__cta-{{ ai_gen_id }} {
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.nav_font_size }}px;
    transition: background-color 0.2s ease;
  }

  .ai-sticky-header__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-header__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-sticky-header__logo-{{ ai_gen_id }} {
      font-size: {{ block.settings.logo_size | times: 0.8 }}px;
    }

    .ai-sticky-header__logo-image-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }

    .ai-sticky-header__nav-{{ ai_gen_id }} {
      gap: {{ block.settings.nav_spacing | times: 0.6 }}px;
    }

    .ai-sticky-header__nav-link-{{ ai_gen_id }},
    .ai-sticky-header__cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.nav_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<sticky-header-{{ ai_gen_id }} class="ai-sticky-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sticky-header__container-{{ ai_gen_id }}">
    <a href="{{ block.settings.logo_link }}" class="ai-sticky-header__logo-{{ ai_gen_id }}">
      {% if block.settings.logo_image %}
        <img
          src="{{ block.settings.logo_image | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          class="ai-sticky-header__logo-image-{{ ai_gen_id }}"
          width="400"
          height="{{ block.settings.logo_height }}"
          loading="eager"
        >
      {% else %}
        {{ block.settings.logo_text }}
      {% endif %}
    </a>

    <nav>
      <ul class="ai-sticky-header__nav-{{ ai_gen_id }}">
        {% if block.settings.nav_link_1_text != blank %}
          <li>
            <a href="{{ block.settings.nav_link_1_url }}" class="ai-sticky-header__nav-link-{{ ai_gen_id }}">
              {{ block.settings.nav_link_1_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.nav_link_2_text != blank %}
          <li>
            <a href="{{ block.settings.nav_link_2_url }}" class="ai-sticky-header__nav-link-{{ ai_gen_id }}">
              {{ block.settings.nav_link_2_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.nav_link_3_text != blank %}
          <li>
            <a href="{{ block.settings.nav_link_3_url }}" class="ai-sticky-header__nav-link-{{ ai_gen_id }}">
              {{ block.settings.nav_link_3_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.nav_link_4_text != blank %}
          <li>
            <a href="{{ block.settings.nav_link_4_url }}" class="ai-sticky-header__nav-link-{{ ai_gen_id }}">
              {{ block.settings.nav_link_4_text }}
            </a>
          </li>
        {% endif %}
        {% if block.settings.cta_text != blank %}
          <li>
            <a href="{{ block.settings.cta_url }}" class="ai-sticky-header__cta-{{ ai_gen_id }}">
              {{ block.settings.cta_text }}
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
</sticky-header-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollThreshold = {{ block.settings.scroll_threshold }};
        this.isScrolled = false;
      }

      connectedCallback() {
        this.handleScroll = this.handleScroll.bind(this);
        window.addEventListener('scroll', this.handleScroll, { passive: true });
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        const scrollPosition = window.scrollY;
        const shouldBeScrolled = scrollPosition > this.scrollThreshold;

        if (shouldBeScrolled !== this.isScrolled) {
          this.isScrolled = shouldBeScrolled;
          this.classList.toggle('scrolled', shouldBeScrolled);
        }
      }
    }

    customElements.define('sticky-header-{{ ai_gen_id }}', StickyHeader{{ ai_gen_id }});
  })();
</script>

