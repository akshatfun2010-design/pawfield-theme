{% doc %}
  @prompt
    I want a header where it can have like home tabs catalog tab about us etc and where I can say like PawFeild and our logo, make the home etc. left, so the order is the Paw Field and then Home, etc, on my logo remove the white bg
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-{{ ai_gen_id }} {
  display: none;
  width: 100%;
  background-color: {{ block.settings.background_color }};
  border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 1000;
}

  .ai-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .ai-header-branding-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .ai-header-logo-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_width }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-header-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-header-site-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.site_name_size }}px;
    font-weight: {{ block.settings.site_name_weight }};
    color: {{ block.settings.site_name_color }};
    margin: 0;
  }

  .ai-header-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.nav_gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-header-nav-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-header-nav-link-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.nav_link_padding }}px {{ block.settings.nav_link_padding | times: 1.5 }}px;
    font-size: {{ block.settings.nav_font_size }}px;
    font-weight: {{ block.settings.nav_font_weight }};
    color: {{ block.settings.nav_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.nav_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-header-nav-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg }};
    color: {{ block.settings.nav_hover_color }};
  }

  .ai-header-mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.nav_text_color }};
    margin-left: auto;
  }

  .ai-header-mobile-toggle-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 768px) {
    .ai-header-container-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .ai-header-mobile-toggle-{{ ai_gen_id }} {
      display: block;
    }

    .ai-header-nav-{{ ai_gen_id }} {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .ai-header-nav-{{ ai_gen_id }}.active {
      display: flex;
    }

    .ai-header-nav-link-{{ ai_gen_id }} {
      padding: 16px;
      border-radius: 0;
    }
  }
  body { padding-top: 120px; }
  #shopify-section-announcement-bar { display: none !important; }

{% endstyle %}

<ai-header-{{ ai_gen_id }} class="ai-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div style="background:#3A6B35;color:white;text-align:center;padding:10px 16px;font-size:13px;font-weight:500;width:100%;letter-spacing:0.3px;">🐾 Free shipping on orders over $60 &middot; Use PAWFIELD10 for 10% off your first order</div>
  <div class="ai-header-container-{{ ai_gen_id }}">
    <a href="{{ block.settings.home_url | default: '/' }}" class="ai-header-branding-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 400 }}"
          alt="{{ block.settings.site_name | escape }}"
          class="ai-header-logo-{{ ai_gen_id }}"
          width="{{ block.settings.logo_width }}"
          height="auto"
          loading="eager"
        >
      {% else %}
        <div class="ai-header-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
      
      {% if block.settings.show_site_name %}
        <h1 class="ai-header-site-name-{{ ai_gen_id }}">{{ block.settings.site_name }}</h1>
      {% endif %}
    </a>

    <nav>
      <ul class="ai-header-nav-{{ ai_gen_id }}">
        {% if block.settings.show_home %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.home_url | default: '/' }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.home_label }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_catalog %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.catalog_url | default: "/collections/all" }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.catalog_label }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_about %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.about_url | default: "/pages/about-us" }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.about_label }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_contact %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.contact_url | default: "/pages/contact" }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.contact_label }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.custom_link_1_label != blank %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.custom_link_1_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.custom_link_1_label }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.custom_link_2_label != blank %}
          <li class="ai-header-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.custom_link_2_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
              {{ block.settings.custom_link_2_label }}
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>

    <button class="ai-header-mobile-toggle-{{ ai_gen_id }}" aria-label="Toggle navigation menu" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</ai-header-{{ ai_gen_id }}>

<script>
  (function() {
    class AiHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.mobileToggle = this.querySelector('.ai-header-mobile-toggle-{{ ai_gen_id }}');
        this.nav = this.querySelector('.ai-header-nav-{{ ai_gen_id }}');
        
        if (this.mobileToggle && this.nav) {
          this.mobileToggle.addEventListener('click', this.toggleNav.bind(this));
        }
      }

      toggleNav() {
        const isActive = this.nav.classList.contains('active');
        this.nav.classList.toggle('active');
        this.mobileToggle.setAttribute('aria-expanded', !isActive);
      }
    }

    customElements.define('ai-header-{{ ai_gen_id }}', AiHeader{{ ai_gen_id }});
  })();
</script>

